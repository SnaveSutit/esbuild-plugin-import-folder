{
	"name": "esbuild-plugin-import-folder",
	"version": "1.0.1",
	"description": "An esbuild plugin to import all files from a folder as if they were imported individually.",
	"author": {
		"name": "Titus Evans (SnaveSutit)",
		"email": "SnaveSutit@gmail.com",
		"url": "https://snavesutit.github.io/"
	},
	"repository": {
		"url": "https://github.com/SnaveSutit/esbuild-plugin-import-folder"
	},
	"files": [
		"dist"
	],
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
