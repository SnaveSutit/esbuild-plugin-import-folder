		"prettier": "^3.6.2",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.46.2",
		"vitest": "^4.0.4"
	},
	"dependencies": {
		"eslint": "^9.38.0"
	},
	"packageManager": "yarn@4.13.0"
